
# Frontend Environment Variables
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...
# Public web URL of your deployed app (used for auth redirect links)
VITE_APP_URL=https://your-project.vercel.app
# Password reset / magic-link redirect target
VITE_AUTH_REDIRECT_URL=https://your-project.vercel.app/forgot-password
VITE_API_BASE_URL=https://busway-backend-9maw.onrender.com
# Optional: if payments are served by your frontend/serverless domain,
# set this to that origin (example: https://your-app.vercel.app)
VITE_PAYMENT_API_BASE_URL=
VITE_PAYU_MERCHANT_KEY=your_payu_merchant_key
VITE_ADMIN_PAYMENT_QR_URL=
VITE_ADMIN_UPI_ID=
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key
VITE_CAMERA_STREAM_BASE_URL=

# Backend Environment Variables
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://your-project.vercel.app
FRONTEND_URLS=https://your-project.vercel.app,https://www.your-domain.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...
PAYU_MERCHANT_KEY=your_payu_merchant_key
PAYU_MERCHANT_SALT=your_payu_merchant_salt
PAYMENT_EMAIL_ENABLED=false
RESEND_API_KEY=
PAYMENT_EMAIL_FROM=BusWay Pro <payments@yourdomain.com>
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+911234567890
# Optional (Twilio trial): force OTP delivery to one verified number only
# Example: +91827881XXXX
VITE_TWILIO_FORCE_TO_NUMBER=
VITE_ALLOW_DEV_OTP=false
GOOGLE_MAPS_API_KEY=your_google_maps_key
