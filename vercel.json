
{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/auth/login",
      "destination": "/api/v1/auth/login"
    },
    {
      "source": "/api/v1/auth/refresh",
      "destination": "/api/v1/auth/refresh"
    },
    {
      "source": "/api/send-otp",
      "destination": "/api/v1/otp/send"
    },
    {
      "source": "/api/verify-otp",
      "destination": "/api/v1/otp/verify"
    },
    {
      "source": "/api/create-razorpay-order",
      "destination": "/api/v1/payments/create-order"
    },
    {
      "source": "/api/verify-razorpay-payment",
      "destination": "/api/v1/payments/verify-payment"
    },
    {
      "source": "/api/razorpay-webhook",
      "destination": "/api/v1/payments/webhook"
    },
    {
      "source": "/api/delete-account",
      "destination": "/api/v1/users/delete"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
